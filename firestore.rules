rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow create: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin']
      );
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin']
      );
    }

    // ── Carts ─────────────────────────────────────────────────────
    // Each authenticated user can only manage their own cart
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Delivery Accounts ─────────────────────────────────────────
    // Any authenticated user can read (needed for auto-assignment at checkout);
    // only store_owner/admin can create/update/delete
    match /deliveryAccounts/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'] ||
        request.auth != null
      );
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'];
    }

    // ── Products ──────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      // store_owner/admin can do any update; customers can only change stock/inStock/updatedAt
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'] ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'inStock', 'updatedAt'])
      );
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'];
    }

    // ── Categories ────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'];
    }

    // ── Orders ────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.customerInfo?.uid ||
        request.auth.uid == resource.data.userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'delivery'
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.customerInfo?.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'] ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'delivery' &&
         resource.data.delivery.assignedTo == request.auth.uid)
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'];
    }

    // ── Coupons ───────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if true;
      // store_owner/admin can do any update; customers can only increment usedCount
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'] ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount', 'updatedAt'])
      );
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['store_owner', 'admin'];
    }

    // ── Reviews / ratings ─────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
